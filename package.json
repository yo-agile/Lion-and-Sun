{
  "name": "lion-and-sun",
  "productName": "Lion and Sun",
  "version": "1.0.0",
  "description": "Psiphon Windows app with protocol selection (CDN fronting, conduit, etc.)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "dev": "electron . --enable-logging"
  },
  "author": "Lion and Sun Team",
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.lionandsun.psiphon",
    "productName": "Lion and Sun",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin/tunnel-core",
        "to": "tunnel-core",
        "filter": ["*.exe"]
      }
    ],
    "asar": true
  }
}